# Cloudflare Pages — cache headers
#
# HTML never cached: always fetched fresh so Vite chunk hashes stay in sync.
# Stale HTML pointing to old chunk URLs causes blank screens on reload.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/*
  Cache-Control: no-cache, no-store, must-revalidate

# JS/CSS chunks are content-addressed (hash in filename) → safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
